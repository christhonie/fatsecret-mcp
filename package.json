{
  "name": "fatsecret-mcp-remote",
  "version": "0.4.0",
  "description": "Remote (Streamable HTTP) FatSecret MCP server for claude.ai custom connectors. Forked from fliptheweb/fatsecret-mcp.",
  "main": "dist/http-server.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/http-server.js",
    "start:stdio": "node dist/index.js",
    "bootstrap": "node dist/bootstrap.js",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "fatsecret",
    "nutrition",
    "diet",
    "claude",
    "remote",
    "http"
  ],
  "author": "Christhonie Geldenhuys",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.0",
    "express": "^4.21.2",
    "ioredis": "^5.11.1",
    "openapi-fetch": "^0.17.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "typescript": "~5.7.0"
  },
  "bin": {
    "fatsecret-mcp-server": "dist/http-server.js",
    "fatsecret-mcp-stdio": "dist/index.js",
    "fatsecret-mcp-bootstrap": "dist/bootstrap.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ]
}
